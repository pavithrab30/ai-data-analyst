# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=nvidia

# ── NVIDIA NIM (free API — get key at https://build.nvidia.com) ───────────────
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# ── Application ────────────────────────────────────────────────────────────────
APP_TITLE=AI Data Analyst
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ── Data ───────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
MAX_ROWS_DISPLAY=1000
MAX_COLUMNS=100
ALLOWED_EXTENSIONS=csv

# ── Execution ─────────────────────────────────────────────────────────────────
CODE_EXECUTION_TIMEOUT=30
MAX_ANOMALY_SAMPLES=10000

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_HISTORY_LIMIT=50

# ── Reports ───────────────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=reports
